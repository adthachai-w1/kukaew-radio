{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/stream.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/stream",
      "destination": "/api/stream.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
